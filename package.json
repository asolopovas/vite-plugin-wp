{
    "name": "@asolopovas/vite-plugin-wp",
    "version": "0.1.1",
    "description": "Vite plugin for WordPress block and theme development with HMR, WP global shimming, and dev-mode env sync.",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src/templates",
        "src/shims",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "bun run build && bun run test && bun run typecheck"
    },
    "keywords": [
        "vite",
        "vite-plugin",
        "wordpress",
        "gutenberg",
        "blocks",
        "hmr"
    ],
    "author": "Andrius Solopovas",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/asolopovas/vite-plugin-wp.git"
    },
    "engines": {
        "node": ">=20"
    },
    "peerDependencies": {
        "vite": ">=8"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/node": "^22",
        "jsdom": "^25",
        "tsup": "^8",
        "typescript": "^5.6",
        "vite": "^8"
    },
    "publishConfig": {
        "access": "public"
    }
}
