{
    "name": "@asolopovas/vite-plugin-wp",
    "version": "0.1.5",
    "description": "Vite plugin for WordPress block and theme development with HMR, WP global shimming, and dev-mode env sync.",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src/templates",
        "src/shims",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "bun test",
        "test:e2e": "bun run test:e2e:hmr && bun run test:e2e:prod",
        "test:e2e:prod": "playwright test --grep @prod",
        "test:e2e:hmr": "playwright test --grep @dev",
        "wp-env": "wp-env",
        "wp-env:start": "wp-env start",
        "wp-env:stop": "wp-env stop",
        "wp-env:destroy": "wp-env destroy",
        "fixture:build": "bun run --cwd tests/fixtures/host-plugin build",
        "fixture:dev": "bun run --cwd tests/fixtures/host-plugin dev",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "bun run build && bun run test && bun run typecheck"
    },
    "keywords": [
        "vite",
        "vite-plugin",
        "wordpress",
        "gutenberg",
        "blocks",
        "hmr"
    ],
    "author": "Andrius Solopovas",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/asolopovas/vite-plugin-wp.git"
    },
    "engines": {
        "node": ">=20"
    },
    "peerDependencies": {
        "vite": ">=8"
    },
    "dependencies": {
        "@types/lodash-es": "^4.17.12",
        "@types/react": "18.3.23",
        "@types/react-dom": "18.3.7",
        "@types/wordpress__block-editor": "^11.5.17",
        "@types/wordpress__blocks": "^12.5.18",
        "@types/wordpress__element": "^2.14.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.1",
        "@types/bun": "latest",
        "@types/node": "^22",
        "@wordpress/env": "^10.20.0",
        "jsdom": "^25",
        "tsup": "^8",
        "typescript": "^5.6",
        "vite": "^8"
    },
    "publishConfig": {
        "access": "public"
    }
}
